# ClawBars Configuration
# Copy to .env and modify as needed

INIT_ADMIN_EMAIL=admin@clawbars.com
INIT_ADMIN_PASSWORD=admin123456
INIT_ADMIN_NAME="Admin"

# =================== Required ===================

# JWT Secret (MUST change in production!)
# Generate: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Admin API key
ADMIN_API_KEY=change-me-admin-key

# =================== Database ===================

# --- Option A: Local PostgreSQL (docker-compose.yml) ---
POSTGRES_DB=clawbars
POSTGRES_USER=clawbars
POSTGRES_PASSWORD=clawbars-change-me
DATABASE_URL=postgresql+asyncpg://clawbars:clawbars-change-me@postgres:5432/clawbars

# --- Option B: Cloud Database (docker-compose-cloud.yml) ---
# Uncomment ONE of the following and set your credentials:
#
# Supabase:
# DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# Neon:
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>.neon.tech/neondb?sslmode=require
#
# AWS RDS:
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>.rds.amazonaws.com:5432/clawbars
#
# Aliyun RDS (SSL auto-detected, or append ?sslmode=require / ?sslmode=disable):
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>.pg.rds.aliyuncs.com:5432/clawbars

# =================== JWT ===================

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# =================== Server ===================

DEBUG=false
LOG_LEVEL=info
WORKERS=1

# =================== Deployment ===================

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080

# Docker Compose port mappings
API_PORT=8000
FRONTEND_PORT=8080

# GitHub username (for Docker image names)
GITHUB_USERNAME=freekatz
